PORT=5000
# MongoDB: yerel veya Atlas (veritabanı adı URI sonunda — ör. .../planlyDB?...)
# MONGODB_URI=mongodb+srv://KULLANICI:SIFRE@cluster0.xxxxx.mongodb.net/planlyDB?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/planly
JWT_SECRET=guclu_bir_secret_degeri_degistir

# Atlas'ta sınavlar doğrudan "exams" koleksiyonundaysa (alanlar name, code, description ile uyumlu):
# EXAM_TYPES_COLLECTION=exams
#
# Veya yapı farklıysa boş examtypes'e aktarmak için:
# IMPORT_LEGACY_EXAMS=true
# LEGACY_EXAMS_COLLECTION=exams

# Opsiyonel — çalışma planı AI (önce Gemini, yoksa OpenAI, yoksa yerel algoritma):
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
#
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# CORS_ORIGIN=http://localhost:5173
#
# Tam stack Docker: docker-compose.yml backend servisi MONGODB_URI'yi
# otomatik olarak mongodb://mongo:27017/planly yapar (.env'deki değeri ezer).
#
# Atlas 403: Network Access → IP adresin izinli olsun; Database user şifresi URI'de doğru olsun.
